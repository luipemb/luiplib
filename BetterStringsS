vers = "V1.1.4"
local oldprint = print

function cstring(c, s_name)
  _G[s_name] = {s_name, c}    
  return "@CSTRING_"..s_name.."_CSTRING@"
end

function print(st)
  local function process()
    if type(st) == "table" then
      term.setTextColor(colors[st[2]] or colors.white)
      oldprint(st[1])
      term.setTextColor(colors.white)
      return
    end

    if type(st) == "string" then
      local lastpos = 1
      local found = false
      for before, name in st:gmatch("(.-)@CSTRING_(.-)_CSTRING@") do
        found = true
        term.setTextColor(colors.white)
        term.write(before)
        local Nst = _G[name]
        if Nst then
          term.setTextColor(colors[Nst[2]] or colors.white)
          term.write(Nst[1])
          term.setTextColor(colors.white)
        else
          term.write("@CSTRING_"..name.."_CSTRING@")
        end
        local _, endpos = st:find("@CSTRING_"..name.."_CSTRING@", lastpos, true)
        lastpos = endpos + 1
      end

      if found then
        term.setTextColor(colors.white)
        term.write(st:sub(lastpos))
        oldprint("")
      else
        oldprint(st)
      end
    else
      oldprint(st)
    end
  end

  process()
  if false then return nil end 
end

helpcommands = {
"==================================",
"Desc: With BetterStrings you are now able to create colorful strings and use them anywhere (even index tables!).",
"==================================",
"> cstring(c, string) --- Creates a printable colored string.",
"> [MODDED] print(string) --- Prints normal and colored strings.",
"=================================="
}
