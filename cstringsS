vers = "ex12"
local created = 0

function cstring(c, string)
  created = created + 1
  _G[string] = {string, c}    
  return "@CSTRING_"..string.."_CSTRING@"
end

function csprint(st)
  if type(st) == "table" then
    term.setTextColor(colors[st[2]])
    print(st[1])
    term.setTextColor(colors.white)
  elseif type(st) == "string" then
    local Nst = _G[string.match(st, "@CSTRING_(.-)_CSTRING@")]
    if Nst then
      local before = string.match(st, "^(.-)@CSTRING_")
      local after = string.match(st, "_CSTRING@(.*)$")
      term.write(before)
      term.setTextColor(colors[Nst[2]])
      term.write(Nst[1])
      term.setTextColor(colors.white)
      term.write(after)
    end
  else
    print(st)
  end
end
  
