function printtab(t, type, tag)
local info = debug.getinfo(2, "Sl")
local line = info.currentline

if t == nil then
insert(errortable, line..": Error--table no specified (>t<, type, order)")
error = true
end

if type == nil then
insert(errortable, line..": Error--type not specified (t, >type<, order)")
insert(errortable, line..": Types: array; key;")
error = true
end

if type == "array" then
for i, v in ipairs(t) do
  if tag then
    print(i..". "..v)
    else
    print(v)
    end
end
end

if type == "key" then
for k, v in pairs(t) do
  if tag then
    print(k..": "..v)
    else
    print(v)
    end
end
end

end



-- 1. Guardamos a função original do shell para não quebrar o PC
local originalRun = shell.run

-- 2. Criamos a nossa versão "tunada" do shell.run
shell.run = function(...)
    -- Roda o programa original e guarda se deu certo e o erro
    local result = { originalRun(...) }
    
    -- Assim que o programa FECHAR (o "end" final dele), isso aqui roda:
    if errortable and next(errortable) then
        tcolor("red")
        print("\n[!] Resumo de erros do programa:")
        -- Printa sua tabela de erros
        for k, v in pairs(errortable) do
            print(k .. ": " .. v)
        end
        tcolor()
        
        -- Limpa para o próximo programa não herdar erros deste
        errortable = {}
    end
    
    -- Devolve o resultado original (importante para o sistema)
    return unpack(result)
end



